{
  "name": "pixeroo",
  "version": "0.1.0",
  "description": "Pixeroo - Private Image Experience Engine. Read. Optimise. Output.",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "npx tailwindcss -i ./shared/styles/input.css -o ./shared/styles/output.css --minify",
    "watch:css": "npx tailwindcss -i ./shared/styles/input.css -o ./shared/styles/output.css --watch",
    "build:wasm": "cd crates && wasm-pack build --target web --out-dir ../shared/wasm/pkg",
    "test": "node --test tests/**/*.test.js",
    "test:js": "node --test tests/utils/*.test.js tests/extension/*.test.js tests/pwa/*.test.js",
    "test:rust": "cd crates && cargo test",
    "test:all": "npm run test:js && npm run test:rust",
    "dev": "npm run watch:css"
  },
  "keywords": ["image", "chrome-extension", "wasm", "rust", "qr-code", "converter"],
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^4.0"
  }
}
