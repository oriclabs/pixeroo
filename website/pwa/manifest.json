{
  "name": "Gazo — Image Toolkit",
  "short_name": "Gazo",
  "description": "Free offline image toolkit — edit, convert, compress, collage, QR, meme, watermark & more. Zero uploads. Grab. Alter. Zone. Output.",
  "start_url": "index.html",
  "id": "/pwa/",
  "scope": "/pwa/",
  "display": "standalone",
  "background_color": "#020617",
  "theme_color": "#F4C430",
  "orientation": "any",
  "lang": "en",
  "dir": "ltr",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "handle_links": "preferred",
  "icons": [
    { "src": "icons/icon-44.png",  "sizes": "44x44",   "type": "image/png" },
    { "src": "icons/icon-50.png",  "sizes": "50x50",   "type": "image/png" },
    { "src": "icons/icon-150.png", "sizes": "150x150", "type": "image/png" },
    { "src": "icons/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "icons/icon-300.png", "sizes": "300x300", "type": "image/png" },
    { "src": "icons/icon-512.png", "sizes": "512x512", "type": "image/png" },
    { "src": "icons/icon-620.png", "sizes": "620x620", "type": "image/png" },
    { "src": "icons/icon-maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "categories": ["utilities", "photo", "productivity"],
  "screenshots": [],
  "file_handlers": [
    {
      "action": "index.html",
      "accept": {
        "image/png":  [".png"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/webp": [".webp"],
        "image/gif":  [".gif"],
        "image/svg+xml": [".svg"],
        "image/bmp":  [".bmp"],
        "image/tiff": [".tiff", ".tif"]
      }
    }
  ],
  "share_target": {
    "action": "index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{ "name": "image", "accept": ["image/*"] }]
    }
  }
}
